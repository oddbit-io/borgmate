<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:BorgMate.ViewModels"
             xmlns:ctrl="using:BorgMate.Views.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="BorgMate.Views.Controls.ProgressPanel"
             x:DataType="vm:JobProgressTracker"
             IsVisible="{Binding HasActiveJob}">

    <DockPanel>
        <Button DockPanel.Dock="Right" Command="{Binding CancelActiveJobCommand}"
                Margin="8,0,0,0"
                Background="Transparent" Foreground="#FF3B30"
                CornerRadius="10" Width="20" Height="20"
                MinWidth="0" MinHeight="0" Padding="0" BorderThickness="0"
                VerticalAlignment="Center">
            <ctrl:BootstrapIcon Kind="StopFill" Width="16" Height="16"/>
        </Button>
        <StackPanel Spacing="2">
            <DockPanel>
                <TextBlock DockPanel.Dock="Right" Classes="secondary"
                           Text="{Binding ActiveElapsed}" Margin="8,0,0,0"/>
                <TextBlock Classes="secondary"
                           Text="{Binding ActiveStatusMessage}"
                           TextTrimming="CharacterEllipsis"/>
            </DockPanel>
            <Panel Height="5" VerticalAlignment="Center">
                <ProgressBar Minimum="0" Maximum="100"
                             Value="{Binding ActiveProgress, FallbackValue=0}"
                             IsIndeterminate="{Binding ActiveProgress, Converter={x:Static ObjectConverters.IsNull}}"
                             MinHeight="5" Height="5" CornerRadius="2.5" Padding="0"/>
            </Panel>
            <TextBlock Classes="secondary" Text="{Binding ActiveProgressDisplay}" Margin="0,2,0,0"/>
        </StackPanel>
    </DockPanel>
</UserControl>
