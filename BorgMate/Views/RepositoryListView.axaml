<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:BorgMate.ViewModels"
             xmlns:models="using:BorgMate.Models"
             xmlns:loc="using:BorgMate.Localization"
             xmlns:ctrl="using:BorgMate.Views.Controls"
             xmlns:conv="clr-namespace:BorgMate.Views.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="340" d:DesignHeight="600"
             x:Class="BorgMate.Views.RepositoryListView"
             x:DataType="vm:RepositoriesPageViewModel">

    <Design.DataContext>
        <x:Static Member="vm:DesignData.RepositoriesPage" />
    </Design.DataContext>

    <DockPanel>
        <!-- Action buttons -->
        <Border DockPanel.Dock="Top" Classes="toolbar">
            <StackPanel Orientation="Horizontal" Spacing="4">
                <ctrl:ToolbarButton Icon="PlusLg"
                                    Label="{Binding [CreateNew], Source={x:Static loc:Strings.Instance}}"
                                    Command="{Binding AddNewCommand}"/>
                <ctrl:ToolbarButton Icon="Folder2Open"
                                    Label="{Binding [OpenExisting], Source={x:Static loc:Strings.Instance}}"
                                    Command="{Binding OpenExistingCommand}"/>
                <ctrl:ToolbarButton Icon="PencilSquare"
                                    Label="{Binding [Edit], Source={x:Static loc:Strings.Instance}}"
                                    Command="{Binding EditRepositoryCommand}"
                                    CommandParameter="{Binding SelectedRepository}"
                                    IsEnabled="{Binding CanEditOrRemove}"/>
                <ctrl:ToolbarButton Icon="PlayFill"
                                    Label="{Binding [Backup], Source={x:Static loc:Strings.Instance}}"
                                    Command="{Binding RunBackupCommand}"
                                    IsEnabled="{Binding CanRunBackup}"/>
                <ctrl:ToolbarButton IsEnabled="{Binding CanEditOrRemove}"
                                    Icon="ThreeDotsVertical"
                                    Label="{Binding [More], Source={x:Static loc:Strings.Instance}}"
                                    Name="MoreButton">
                    <ctrl:ToolbarButton.Flyout>
                        <MenuFlyout Placement="BottomEdgeAlignedLeft">
                            <MenuItem Header="{Binding [Compact], Source={x:Static loc:Strings.Instance}}"
                                      Command="{Binding CompactRepoCommand}">
                                <MenuItem.Icon>
                                    <ctrl:BootstrapIcon Kind="ArrowsCollapse" Width="14" Height="14" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="{Binding [Check], Source={x:Static loc:Strings.Instance}}"
                                      Command="{Binding CheckRepoCommand}">
                                <MenuItem.Icon>
                                    <ctrl:BootstrapIcon Kind="ShieldCheck" Width="14" Height="14" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="{Binding [Prune], Source={x:Static loc:Strings.Instance}}"
                                      Command="{Binding PruneRepoCommand}"
                                      IsEnabled="{Binding SelectedRepository.PruneOptions.HasAnyRetention, FallbackValue=False}">
                                <MenuItem.Icon>
                                    <ctrl:BootstrapIcon Kind="Scissors" Width="14" Height="14" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <Separator />
                            <MenuItem Header="{Binding [Duplicate], Source={x:Static loc:Strings.Instance}}"
                                      Command="{Binding DuplicateRepositoryCommand}"
                                      CommandParameter="{Binding SelectedRepository}">
                                <MenuItem.Icon>
                                    <ctrl:BootstrapIcon Kind="Files" Width="14" Height="14" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <Separator />
                            <MenuItem Header="{Binding [Remove], Source={x:Static loc:Strings.Instance}}"
                                      Command="{Binding RemoveRepositoryCommand}"
                                      CommandParameter="{Binding SelectedRepository}">
                                <MenuItem.Icon>
                                    <ctrl:BootstrapIcon Kind="Trash" Width="14" Height="14" />
                                </MenuItem.Icon>
                            </MenuItem>
                        </MenuFlyout>
                    </ctrl:ToolbarButton.Flyout>
                </ctrl:ToolbarButton>
            </StackPanel>
        </Border>

        <!-- Repository detail panel (bottom) -->
        <Border DockPanel.Dock="Bottom"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                Height="92">
            <Panel>
                <TextBlock Text="{Binding [SelectRepoDetail], Source={x:Static loc:Strings.Instance}}"
                           Classes="placeholder"
                           IsVisible="{Binding SelectedRepository, Converter={x:Static ObjectConverters.IsNull}}" />
                <ScrollViewer Margin="12,8" VerticalScrollBarVisibility="Auto"
                              IsVisible="{Binding SelectedRepository, Converter={x:Static ObjectConverters.IsNotNull}}">
                    <StackPanel Spacing="2">
                        <StackPanel Spacing="2" Margin="0,0,0,2">
                            <DockPanel>
                                <ctrl:SpinnerControl DockPanel.Dock="Right" Width="16" Height="16"
                                                     VerticalAlignment="Center"
                                                     Foreground="{DynamicResource SecondaryTextBrush}"
                                                     IsVisible="{Binding SelectedRepository.IsLoadingStats}" />
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <ctrl:BootstrapIcon Kind="Database" Width="14" Height="14"
                                                               VerticalAlignment="Center"
                                                               Foreground="{DynamicResource SecondaryTextBrush}" />
                                    <TextBlock Text="{Binding SelectedRepository.Name}" FontWeight="SemiBold" />
                                </StackPanel>
                            </DockPanel>
                            <TextBlock Classes="secondary" Text="{Binding SelectedRepository.Path}"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>

                        <!-- Operation progress (shown when repo is busy) -->
                        <ctrl:ProgressPanel DataContext="{Binding Progress}"/>

                        <!-- Stats grid (hidden when busy) -->
                        <Grid ColumnDefinitions="120,8,*" RowDefinitions="Auto,4,Auto">
                            <Grid.IsVisible>
                                <MultiBinding Converter="{x:Static BoolConverters.And}">
                                    <Binding Path="SelectedRepository.HasStats" />
                                    <Binding Path="Progress.HasActiveJob" Converter="{x:Static BoolConverters.Not}" />
                                </MultiBinding>
                            </Grid.IsVisible>
                            <TextBlock Grid.Row="0" Grid.Column="0" Classes="secondary"
                                       Text="{Binding [TotalSize], Source={x:Static loc:Strings.Instance}}" />
                            <TextBlock Grid.Row="0" Grid.Column="2" Classes="secondary"
                                       Text="{Binding SelectedRepository.StatsTotalSize, Converter={x:Static conv:FormatBytesConverter.Instance}}" />
                            <TextBlock Grid.Row="2" Grid.Column="0" Classes="secondary"
                                       Text="{Binding [TotalChunks], Source={x:Static loc:Strings.Instance}}" />
                            <TextBlock Grid.Row="2" Grid.Column="2" Classes="secondary"
                                       Text="{Binding SelectedRepository.StatsTotalChunks, Converter={x:Static conv:FormatNumberConverter.Instance}}" />
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Panel>
        </Border>

        <!-- Repository list header -->
        <Border DockPanel.Dock="Top" Padding="8,6" BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1" MinHeight="32">
            <TextBlock Text="{Binding [Repositories], Source={x:Static loc:Strings.Instance}}" FontWeight="SemiBold"
                       FontSize="{StaticResource SecondaryFontSize}" Foreground="{DynamicResource SecondaryTextBrush}"
                       VerticalAlignment="Center" />
        </Border>

        <!-- Repository list -->
        <ListBox ItemsSource="{Binding Repositories}"
                 SelectedItem="{Binding SelectedRepository}"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.Styles>
                <Style Selector="ListBoxItem:selected ctrl|SpinnerControl">
                    <Setter Property="Foreground" Value="White"/>
                </Style>
                <Style Selector="ListBoxItem:selected ctrl|CircularProgressControl">
                    <Setter Property="Foreground" Value="White"/>
                </Style>
            </ListBox.Styles>
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="models:BorgRepository">
                    <DockPanel Margin="8,4" MinHeight="30">
                        <Grid Width="18" Height="18" VerticalAlignment="Center" Margin="4,0,14,0">
                            <ctrl:BootstrapIcon Kind="Database" Width="18" Height="18">
                                <ctrl:BootstrapIcon.IsVisible>
                                    <Binding Path="IsBusy" Converter="{x:Static BoolConverters.Not}" />
                                </ctrl:BootstrapIcon.IsVisible>
                            </ctrl:BootstrapIcon>
                            <ctrl:SpinnerControl Width="16" Height="16"
                                                 Foreground="{DynamicResource SecondaryTextBrush}">
                                <ctrl:SpinnerControl.IsVisible>
                                    <MultiBinding Converter="{x:Static BoolConverters.And}">
                                        <Binding Path="IsBusy"/>
                                        <Binding Path="CommandProgress" Converter="{x:Static ObjectConverters.IsNull}"/>
                                    </MultiBinding>
                                </ctrl:SpinnerControl.IsVisible>
                            </ctrl:SpinnerControl>
                            <ctrl:CircularProgressControl Width="18" Height="18"
                                                          Value="{Binding CommandProgress}"
                                                          Foreground="{DynamicResource SecondaryTextBrush}">
                                <ctrl:CircularProgressControl.IsVisible>
                                    <MultiBinding Converter="{x:Static BoolConverters.And}">
                                        <Binding Path="IsBusy"/>
                                        <Binding Path="CommandProgress" Converter="{x:Static ObjectConverters.IsNotNull}"/>
                                    </MultiBinding>
                                </ctrl:CircularProgressControl.IsVisible>
                            </ctrl:CircularProgressControl>
                        </Grid>
                        <!-- Error indicator: docked right, vertically centered, tooltip shows the full LastError. -->
                        <ctrl:BootstrapIcon DockPanel.Dock="Right"
                                            Kind="ExclamationCircle"
                                            Width="16" Height="16"
                                            VerticalAlignment="Center"
                                            Margin="8,0,4,0"
                                            Foreground="{StaticResource ValidationErrorBrush}"
                                            IsVisible="{Binding HasError}"
                                            ToolTip.Tip="{Binding LastError}"/>
                        <StackPanel VerticalAlignment="Center" ToolTip.Tip="{Binding Path}">
                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <ctrl:BootstrapIcon Kind="Clock" Width="10" Height="10"
                                    VerticalAlignment="Center"
                                    Foreground="{DynamicResource SecondaryTextBrush}"
                                    IsVisible="{Binding IsScheduled}"/>
                                <TextBlock Classes="secondary"
                                           TextTrimming="CharacterEllipsis">
                                    <TextBlock.Text>
                                        <MultiBinding Converter="{x:Static conv:ScheduleDisplayConverter.Instance}">
                                            <Binding Path="."/>
                                            <Binding Path="IsScheduled"/>
                                            <Binding Path="LastBackupAt"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                    </DockPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</UserControl>