<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:BorgMate.ViewModels"
        xmlns:loc="using:BorgMate.Localization"
        xmlns:conv="using:BorgMate.Views.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        x:Class="BorgMate.Views.AppSettingsWindow"
        x:DataType="vm:AppSettingsViewModel"
        Title="{Binding [AppSettings], Source={x:Static loc:Strings.Instance}}"
        Width="460"
        Height="510"
        CanResize="False"
        WindowStartupLocation="CenterOwner">

    <Window.Styles>
        <Style Selector="TextBlock:disabled">
            <Setter Property="Opacity" Value="0.35"/>
        </Style>
    </Window.Styles>

    <Design.DataContext>
        <vm:AppSettingsViewModel/>
    </Design.DataContext>

    <DockPanel Margin="{StaticResource ModalPadding}">
        <StackPanel Classes="dialog-buttons">
            <Button Content="{Binding [Close], Source={x:Static loc:Strings.Instance}}" Name="CloseButton"/>
            <Button Content="{Binding [Save], Source={x:Static loc:Strings.Instance}}" Command="{Binding SaveCommand}" Classes="accent"/>
        </StackPanel>

        <TabControl>
            <!-- General -->
            <TabItem Header="{Binding [General], Source={x:Static loc:Strings.Instance}}">
                <ScrollViewer>
                    <StackPanel Spacing="{StaticResource FormSpacing}" Margin="0,12,0,0">
                        <Grid ColumnDefinitions="*,12,*">
                            <StackPanel Grid.Column="0" Spacing="{StaticResource FieldSpacing}">
                                <TextBlock Text="{Binding [Language], Source={x:Static loc:Strings.Instance}}"/>
                                <ComboBox ItemsSource="{Binding Languages}"
                                          SelectedItem="{Binding SelectedLanguage}"
                                          HorizontalAlignment="Stretch"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Spacing="{StaticResource FieldSpacing}">
                                <TextBlock Text="{Binding [Theme], Source={x:Static loc:Strings.Instance}}"/>
                                <ComboBox ItemsSource="{Binding Themes}"
                                          SelectedItem="{Binding SelectedTheme}"
                                          HorizontalAlignment="Stretch">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Converter={x:Static conv:ThemeConverter.Instance}}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>
                        </Grid>

                        <GroupBox Header="{Binding [AppSettings.Group.Startup], Source={x:Static loc:Strings.Instance}}">
                            <StackPanel Spacing="10">
                                <CheckBox IsChecked="{Binding StartAtLogin}" Content="{Binding [StartAtLogin], Source={x:Static loc:Strings.Instance}}"/>
                                <CheckBox IsChecked="{Binding StartMinimized}" Content="{Binding [StartMinimized], Source={x:Static loc:Strings.Instance}}"/>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="{Binding [AppSettings.Group.Notifications], Source={x:Static loc:Strings.Instance}}">
                            <StackPanel Spacing="10">
                                <CheckBox IsChecked="{Binding CheckForUpdates}" Content="{Binding [CheckForUpdates], Source={x:Static loc:Strings.Instance}}"/>
                                <CheckBox IsChecked="{Binding ShowNotifications}" Content="{Binding [ShowNotifications], Source={x:Static loc:Strings.Instance}}"/>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="{Binding [AppSettings.Group.AutoLoad], Source={x:Static loc:Strings.Instance}}">
                            <StackPanel Spacing="10">
                                <CheckBox IsChecked="{Binding AutoLoadArchives}" Content="{Binding [AppSettings.AutoLoadArchives], Source={x:Static loc:Strings.Instance}}"/>
                                <CheckBox IsChecked="{Binding AutoLoadStats}" Content="{Binding [AppSettings.AutoLoadStats], Source={x:Static loc:Strings.Instance}}"/>
                                <CheckBox IsChecked="{Binding AutoLoadArchiveDetails}" Content="{Binding [AppSettings.AutoLoadArchiveDetails], Source={x:Static loc:Strings.Instance}}"/>
                            </StackPanel>
                        </GroupBox>

                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <CheckBox IsChecked="{Binding IsJournalRetentionEnabled}" Content="{Binding [JournalRetention], Source={x:Static loc:Strings.Instance}}"/>
                            <ComboBox ItemsSource="{Binding RetentionPeriods}"
                                      SelectedItem="{Binding JournalRetention}"
                                      IsEnabled="{Binding IsJournalRetentionEnabled}"
                                      Width="140">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Converter={x:Static conv:RetentionPeriodConverter.Instance}}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Advanced -->
            <TabItem Header="{Binding [Advanced], Source={x:Static loc:Strings.Instance}}">
                <ScrollViewer>
                    <StackPanel Spacing="{StaticResource FormSpacing}" Margin="0,12,0,0">
                        <StackPanel Spacing="{StaticResource FieldSpacing}">
                            <TextBlock Text="{Binding [BorgPathOverride], Source={x:Static loc:Strings.Instance}}"/>
                            <TextBox Text="{Binding BorgBinaryPath}" PlaceholderText="{Binding DetectedBorgPath}"/>
                            <TextBlock Text="{Binding DetectedBorgPathDisplay}" Classes="secondary" FontSize="12"/>
                        </StackPanel>

                        <CheckBox IsChecked="{Binding LoggingEnabled}" Content="{Binding [EnableLogging], Source={x:Static loc:Strings.Instance}}"/>

                        <StackPanel Orientation="Horizontal" Spacing="12" IsEnabled="{Binding LoggingEnabled}">
                            <StackPanel Spacing="2">
                                <TextBlock Text="{Binding [LogLevel], Source={x:Static loc:Strings.Instance}}" Classes="secondary" FontSize="11"/>
                                <ComboBox ItemsSource="{Binding LogLevels}"
                                          SelectedItem="{Binding LogLevel}"
                                          Width="140">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Converter={x:Static conv:LogLevelConverter.Instance}}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Spacing="2">
                                <TextBlock Text="{Binding [LogRetentionPeriod], Source={x:Static loc:Strings.Instance}}" Classes="secondary" FontSize="11"/>
                                <ComboBox ItemsSource="{Binding RetentionPeriods}"
                                          SelectedItem="{Binding LogRetention}"
                                          Width="140">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Converter={x:Static conv:RetentionPeriodConverter.Instance}}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Spacing="{StaticResource FieldSpacing}">
                            <TextBlock Text="{Binding [SshKeepAlive], Source={x:Static loc:Strings.Instance}}"/>
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="{Binding [SshKeepAliveInterval], Source={x:Static loc:Strings.Instance}}" Classes="secondary" FontSize="11"/>
                                    <NumericUpDown Value="{Binding SshKeepAliveInterval}" Minimum="0" Maximum="600" Increment="5" Width="140" FormatString="0"/>
                                </StackPanel>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="{Binding [SshKeepAliveCountMax], Source={x:Static loc:Strings.Instance}}" Classes="secondary" FontSize="11"/>
                                    <NumericUpDown Value="{Binding SshKeepAliveCountMax}" Minimum="1" Maximum="30" Increment="1" Width="140" FormatString="0"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>

                        <CheckBox IsChecked="{Binding BinaryUnits}" Content="{Binding [BinaryUnits], Source={x:Static loc:Strings.Instance}}"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
