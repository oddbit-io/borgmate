<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:BorgMate.ViewModels"
             xmlns:models="using:BorgMate.Models"
             xmlns:loc="using:BorgMate.Localization"
             xmlns:ctrl="using:BorgMate.Views.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="750" d:DesignHeight="450"
             x:Class="BorgMate.Views.ArchiveListView"
             x:DataType="vm:ArchiveListViewModel">

    <Design.DataContext>
        <x:Static Member="vm:DesignData.ArchiveList"/>
    </Design.DataContext>

    <DockPanel>
        <!-- Action buttons -->
        <Border DockPanel.Dock="Top" Classes="toolbar">
            <DockPanel>
                <Button DockPanel.Dock="Right" Command="{Binding DeleteArchiveCommand}"
                        IsEnabled="{Binding CanModifyArchive}"
                        Classes="toolbar-btn">
                    <StackPanel Spacing="3" HorizontalAlignment="Center">
                        <ctrl:BootstrapIcon Kind="Trash" Width="16" Height="16" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding [Delete], Source={x:Static loc:Strings.Instance}}" FontSize="10" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <Button Command="{Binding PickAndRestoreCommand}"
                            IsEnabled="{Binding CanModifyArchive}"
                            Classes="toolbar-btn">
                        <StackPanel Spacing="3" HorizontalAlignment="Center">
                            <ctrl:BootstrapIcon Kind="BoxArrowDown" Width="16" Height="16" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding [RestoreTo], Source={x:Static loc:Strings.Instance}}" FontSize="10" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding BrowseAndRestoreCommand}"
                            IsEnabled="{Binding CanModifyArchive}"
                            Classes="toolbar-btn">
                        <StackPanel Spacing="3" HorizontalAlignment="Center">
                            <ctrl:BootstrapIcon Kind="ListNested" Width="16" Height="16" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding [BrowseRestore], Source={x:Static loc:Strings.Instance}}" FontSize="10" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding ListArchivesCommand}" IsEnabled="{Binding IsRepoIdle}" Classes="toolbar-btn">
                        <StackPanel Spacing="3" HorizontalAlignment="Center">
                            <ctrl:BootstrapIcon Kind="ArrowClockwise" Width="16" Height="16" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding [Refresh], Source={x:Static loc:Strings.Instance}}" FontSize="10" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Archives header -->
        <Border DockPanel.Dock="Top" Padding="8,6" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" MinHeight="32">
            <TextBlock Text="{Binding [Archives], Source={x:Static loc:Strings.Instance}}" FontWeight="SemiBold"
                       FontSize="{StaticResource SecondaryFontSize}" Foreground="{DynamicResource SecondaryTextBrush}"
                       VerticalAlignment="Center"/>
        </Border>

        <!-- Column sort -->
        <Border DockPanel.Dock="Top" Padding="4" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <DockPanel>
                <Button DockPanel.Dock="Right"
                        Command="{Binding SortByDateCommand}"
                        Background="Transparent" BorderThickness="0" Padding="4" Cursor="Hand"
                        MinWidth="0">
                    <TextBlock FontSize="{StaticResource SecondaryFontSize}"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               FontWeight="SemiBold">
                        <Run Text="{Binding [DateHeader], Source={x:Static loc:Strings.Instance}}"/>
                        <Run Text="{Binding DateSortIndicator}"/>
                    </TextBlock>
                </Button>
                <Button DockPanel.Dock="Left" Command="{Binding SortByNameCommand}"
                        Background="Transparent" BorderThickness="0" Padding="4" Cursor="Hand"
                        HorizontalAlignment="Left" MinWidth="0">
                    <TextBlock FontSize="{StaticResource SecondaryFontSize}"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               FontWeight="SemiBold">
                        <Run Text="{Binding [NameHeader], Source={x:Static loc:Strings.Instance}}"/>
                        <Run Text="{Binding NameSortIndicator}"/>
                    </TextBlock>
                </Button>
            </DockPanel>
        </Border>

        <!-- Detail panel (bottom) -->
        <Border DockPanel.Dock="Bottom"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                Height="92"
>
            <Panel>
                <TextBlock Text="{Binding [SelectArchiveDetail], Source={x:Static loc:Strings.Instance}}"
                           Classes="placeholder"
                           IsVisible="{Binding SelectedArchive, Converter={x:Static ObjectConverters.IsNull}}"/>
                <ScrollViewer Margin="12,8" VerticalScrollBarVisibility="Auto"
                              IsVisible="{Binding SelectedArchive, Converter={x:Static ObjectConverters.IsNotNull}}">
                <StackPanel Spacing="2">
                    <DockPanel Margin="0,0,0,2">
                        <Panel DockPanel.Dock="Right" VerticalAlignment="Top" Margin="8,0,0,0"
                               IsVisible="{Binding HasSelectedArchive}">
                            <ctrl:SpinnerControl Width="16" Height="16"
                                                 Foreground="{DynamicResource SecondaryTextBrush}"
                                                 IsVisible="{Binding IsLoadingDetail}" />
                        </Panel>
                        <StackPanel Spacing="2">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <ctrl:BootstrapIcon Kind="Box" Width="14" Height="14"
                                    VerticalAlignment="Center"
                                    Foreground="{DynamicResource SecondaryTextBrush}"/>
                                <TextBlock Text="{Binding SelectedArchive.Name}" FontWeight="SemiBold"/>
                            </StackPanel>
                            <TextBlock Classes="secondary" Text="{Binding SelectedArchive.DateDisplay}"/>
                        </StackPanel>
                    </DockPanel>

                    <!-- Restore progress -->
                    <DockPanel IsVisible="{Binding Progress.HasActiveJob}">
                        <Button DockPanel.Dock="Right" Command="{Binding Progress.CancelActiveJobCommand}"
                                Margin="8,0,0,0"
                                Background="Transparent" Foreground="#FF3B30"
                                CornerRadius="10" Width="20" Height="20"
                                MinWidth="0" MinHeight="0" Padding="0" BorderThickness="0"
                                VerticalAlignment="Center">
                            <ctrl:BootstrapIcon Kind="StopFill" Width="10" Height="10" />
                        </Button>
                        <StackPanel Spacing="2">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Right" Classes="secondary"
                                           Text="{Binding Progress.ActiveElapsed}" Margin="8,0,0,0"/>
                                <TextBlock Classes="secondary"
                                           Text="{Binding Progress.ActiveStatusMessage}"
                                           TextTrimming="CharacterEllipsis" />
                            </DockPanel>
                            <Panel Height="5" VerticalAlignment="Center">
                                <ProgressBar Minimum="0" Maximum="100"
                                             Value="{Binding Progress.ActiveProgress, FallbackValue=0}"
                                             IsIndeterminate="{Binding Progress.ActiveProgress, Converter={x:Static ObjectConverters.IsNull}}"
                                             MinHeight="5" Height="5" CornerRadius="2.5" Padding="0" />
                            </Panel>
                            <TextBlock Classes="secondary" Text="{Binding Progress.ActiveProgressDisplay}" Margin="0,2,0,0"/>
                        </StackPanel>
                    </DockPanel>

                    <!-- Archive stats (hidden during restore) -->
                    <Grid ColumnDefinitions="120,8,*" RowDefinitions="Auto,4,Auto">
                        <Grid.IsVisible>
                            <MultiBinding Converter="{x:Static BoolConverters.And}">
                                <Binding Path="HasDetail"/>
                                <Binding Path="Progress.HasActiveJob" Converter="{x:Static BoolConverters.Not}"/>
                            </MultiBinding>
                        </Grid.IsVisible>
                        <TextBlock Grid.Row="0" Grid.Column="0" Classes="secondary" Text="{Binding [OriginalSize], Source={x:Static loc:Strings.Instance}}"/>
                        <TextBlock Grid.Row="0" Grid.Column="2" Classes="secondary" Text="{Binding DetailOriginalSize}"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Classes="secondary" Text="{Binding [Files], Source={x:Static loc:Strings.Instance}}"/>
                        <TextBlock Grid.Row="2" Grid.Column="2" Classes="secondary" Text="{Binding DetailFileCount}"/>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
            </Panel>
        </Border>

        <Panel>
            <!-- Busy spinner (loading or deleting) -->
            <StackPanel IsVisible="{Binding IsArchiveBusy}"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Spacing="8" Orientation="Horizontal">
                <ctrl:SpinnerControl Width="16" Height="16"
                                     Foreground="{DynamicResource SecondaryTextBrush}" />
                <TextBlock Classes="secondary" VerticalAlignment="Center">
                    <TextBlock.IsVisible>
                        <Binding Path="IsLoadingArchives"/>
                    </TextBlock.IsVisible>
                    <TextBlock.Text>
                        <Binding Path="[Status.LoadingArchives]" Source="{x:Static loc:Strings.Instance}"/>
                    </TextBlock.Text>
                </TextBlock>
                <TextBlock Classes="secondary" VerticalAlignment="Center">
                    <TextBlock.IsVisible>
                        <Binding Path="IsDeletingArchive"/>
                    </TextBlock.IsVisible>
                    <TextBlock.Text>
                        <Binding Path="[DeletingArchive]" Source="{x:Static loc:Strings.Instance}"/>
                    </TextBlock.Text>
                </TextBlock>
            </StackPanel>

            <ListBox ItemsSource="{Binding Archives}"
                     IsVisible="{Binding !IsArchiveBusy}"
                     IsEnabled="{Binding IsRepoIdle}"
                     SelectedItem="{Binding SelectedArchive}"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="models:BorgArchive">
                        <DockPanel Margin="8,4" MinHeight="30">
                            <ctrl:BootstrapIcon Kind="Box" Width="18" Height="18" VerticalAlignment="Center" Margin="4,0,14,0"/>
                            <TextBlock DockPanel.Dock="Right" Classes="secondary" VerticalAlignment="Center"
                                       Margin="8,0,0,0"
                                       Text="{Binding DateDisplay}"/>
                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>
                        </DockPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Panel>
    </DockPanel>
</UserControl>
