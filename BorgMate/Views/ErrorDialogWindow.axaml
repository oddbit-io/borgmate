<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="using:BorgMate.Localization"
        xmlns:ctrl="using:BorgMate.Views.Controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="420" d:DesignHeight="160"
        x:Class="BorgMate.Views.ErrorDialogWindow"
        Title="{Binding Source={x:Static loc:Strings.Instance}, Path=[ErrorTitle]}"
        Width="420"
        MaxHeight="400"
        SizeToContent="Height"
        CanResize="False"
        WindowStartupLocation="CenterOwner">

    <DockPanel Margin="{StaticResource ModalPadding}">
        <StackPanel Classes="dialog-buttons">
            <Button Content="{Binding [OK], Source={x:Static loc:Strings.Instance}}" Name="OkButton" Classes="accent"/>
        </StackPanel>

        <DockPanel Margin="0,0,0,8">
            <ctrl:BootstrapIcon Kind="ExclamationCircle" Width="28" Height="28"
                                       Foreground="#E55" VerticalAlignment="Top" Margin="0,2,14,0"
                                       DockPanel.Dock="Left"/>
            <StackPanel Spacing="8">
                <!-- Repository header (hidden when no repo context) -->
                <StackPanel Name="RepoHeader" Spacing="2" IsVisible="False">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <ctrl:BootstrapIcon Kind="Database" Width="14" Height="14"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <TextBlock Name="RepoNameText" FontWeight="SemiBold"/>
                    </StackPanel>
                    <TextBlock Name="RepoPathText" FontSize="11"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>

                <!-- Error message -->
                <ScrollViewer MaxHeight="300">
                    <TextBlock Name="MessageText" TextWrapping="Wrap"/>
                </ScrollViewer>
            </StackPanel>
        </DockPanel>
    </DockPanel>
</Window>
